# ══════════════════════════════════════════════════════════
#  .gitignore - إنجاز للحلول الذكية
# ══════════════════════════════════════════════════════════

# ── ملفات الإعدادات الحساسة ────────────────────────────────
config/db.php

# ── قواعد البيانات والنسخ الاحتياطية ──────────────────────
*.sql
*.sqlite
*.db
database/*.sql

# ── ملفات السجلات ──────────────────────────────────────────
*.log
logs/

# ── ملفات النظام والمؤقتة ──────────────────────────────────
node_modules/
.env
.env.*
*.bak
*.tmp
*.swp

# ── ملفات الضغط ────────────────────────────────────────────
*.zip
*.tar.gz
*.rar

# ── ملفات بيئة التطوير ─────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ── ملفات الرفع/الإيصالات (ان وجدت) ───────────────────────
uploads/receipts/

# ── ملف الاستيراد لمرة واحدة ───────────────────────────────
import_clients.php
